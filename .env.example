# IBM watsonx Orchestrate Credentials
# Copy this file to .env and fill in your values

# Required: Your IBM Cloud API key
ORCHESTRATE_API_KEY="your-api-key-here"

# Required: Your Orchestrate instance ID
ORCHESTRATE_INSTANCE_ID="your-instance-id-here"

# Optional: Region (default: us-south)
# Options: us-south, eu-gb, eu-de, au-syd, jp-tok
ORCHESTRATE_REGION="us-south"

# Optional: Specific agent ID to use
# If not set, the default agent will be used
ORCHESTRATE_AGENT_ID=""
